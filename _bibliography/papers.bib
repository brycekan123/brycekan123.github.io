@inproceedings{yang2026ramem,
  abbr        = {NeurIPS},
  bibtex_show = {true},
  title       = {RaMem: Contextual Reinstatement for Long-Term Agentic Memory},
  author      = {Yang, W. and Kan, B. and others},
  booktitle   = {Advances in Neural Information Processing Systems (NeurIPS)},
  year        = {2026},
  selected    = {true},
  preview     = {ramem.png},
  abstract    = {We present RaMem, a RAG-based agentic memory pipeline enabling LLM agents to recall evidence across multi-session conversations. By combining hybrid retrieval with Reciprocal Rank Fusion over semantic search and BM25, RaMem improves F1 by 11.6 points across GPT-4o, GPT-4.1-mini, and Qwen3-8B, while reducing retrieved-memory context by 50%.}
}

@article{kan2026job,
  abbr        = {arXiv},
  bibtex_show = {true},
  title       = {De-conflating Preference and Qualification: Constrained Dual-Perspective Reasoning for Job Recommendation with Large Language Models},
  author      = {Kan, B. and others},
  journal     = {arXiv preprint},
  year        = {2026},
  url         = {https://arxiv.org/abs/2602.03097},
  html        = {https://arxiv.org/abs/2602.03097},
  selected    = {true},
  preview     = {jobrec.png},
  abstract    = {We tackle cold-start scenarios in job recommendation using synthetic explanation generation via GPT-4o-mini distillation into Llama-3-8B-Instruct. Our multi-step fine-tuning with dual optimization achieves up to 2.6x (Recall@5) and over 3x (NDCG@5) improvement over LLM baselines.}
}

